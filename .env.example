# Mistral API Configuration
# Get your API key from https://console.mistral.ai/
MISTRAL_API_KEY=...
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# LLM Model for document generation
# Available models: mistral-small-latest, mistral-medium-latest, mistral-large-latest
LLM_MODEL=mistral-small-latest

# Embedding Model (local, downloaded from HuggingFace)
EMBEDDING_MODEL=deepvk/USER-bge-m3

# RAG Settings
CHUNK_SIZE=256
CHUNK_OVERLAP=64
TOP_K_RESULTS=5
DOC_MIN_SCORE=0.5

# Vector Database Settings
# Directory for ChromaDB persistence
CHROMA_PERSIST_DIR=./data/chroma_db

# Data Directory
# Path to directory containing HTML source documents
DATA_DIR=./data

# Server Settings
DEBUG=false
HOST=0.0.0.0
PORT=8000
